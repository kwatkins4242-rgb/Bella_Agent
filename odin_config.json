{
  "_comment": "ODIN Master Config — set ACTIVE_BRAIN, ACTIVE_REASONING, ACTIVE_FALLBACK to any provider key. Each provider has type, connection, and full model list.",

  "ACTIVE_BRAIN":     "ollama",
  "ACTIVE_REASONING": "bedrock",
  "ACTIVE_FALLBACK":  "openrouter",

  "providers": {

    "ollama": {
      "type": "openai_compat",
      "base_url": "http://localhost:11434/v1",
      "base_url_env": "OLLAMA_BASE_URL",
      "api_key": "ollama",
      "api_key_env": "OLLAMA_API_KEY",
      "default_model": "odin:latest",
      "default_model_env": "OLLAMA_MODEL",
      "supports_tools": true,
      "local": true,
      "models": [
        {"id": "odin:latest",              "label": "ODIN (fine-tuned qwen2.5-3B)",  "capabilities": ["chat", "tool"]},
        {"id": "odin_3b1e40b9888a",        "label": "ODIN v2 (alt tag)",             "capabilities": ["chat", "tool"]},
        {"id": "bella:latest",             "label": "Bella (fine-tuned qwen3-30B)",  "capabilities": ["chat", "tool", "reasoning"]},
        {"id": "qwen2.5:3b",               "label": "Qwen2.5 3B (base)",             "capabilities": ["chat", "tool"]},
